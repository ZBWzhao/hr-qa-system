{
  "meta": {
    "version": "1.0",
    "default_user": "emp001",
    "default_password": "123456",
    "api_base": "http://127.0.0.1:8000/api/v1"
  },
  "unit_scripts": [
    "test_faq_match.py",
    "test_ticket_flow.py",
    "test_attendance_slots.py",
    "test_ai_enhance.py",
    "test_followup.py"
  ],
  "single_turn": [
    {
      "id": "Q-01",
      "module": "FAQ",
      "question": "年假怎么计算？",
      "expected_types": ["faq"],
      "must_contain": ["5天", "工龄"],
      "summary": "按工龄 1–10 年 5 天、10–20 年 10 天、20 年以上 15 天"
    },
    {
      "id": "Q-02",
      "module": "FAQ",
      "question": "请假需要提前多久申请？",
      "expected_types": ["faq"],
      "must_contain": ["OA", "审批"],
      "summary": "分级审批；年假提前 3 个工作日"
    },
    {
      "id": "Q-03",
      "module": "FAQ",
      "question": "加班可以调休吗？",
      "expected_types": ["faq"],
      "must_contain": ["调休", "1.5"],
      "summary": "工作日 1.5 倍/调休，周末 2 倍，法定 3 倍"
    },
    {
      "id": "Q-04",
      "module": "FAQ",
      "question": "试用期多久？",
      "expected_types": ["faq"],
      "must_contain": ["3个月"],
      "summary": "试用期 3 个月，工资为转正 80%"
    },
    {
      "id": "Q-05",
      "module": "FAQ",
      "question": "报销流程是什么？",
      "expected_types": ["faq"],
      "must_contain": ["报销", "发票"],
      "summary": "5 步报销流程，30 天内提交"
    },
    {
      "id": "Q-06",
      "module": "FAQ",
      "question": "绩效申诉怎么提交？",
      "expected_types": ["faq"],
      "must_contain": ["申诉", "5个工作日"],
      "summary": "结果公布后 5 个工作日内提出，HR 10 工作日反馈"
    },
    {
      "id": "Q-07",
      "module": "规则",
      "question": "HR电话是多少？",
      "expected_types": ["rule"],
      "must_contain": ["88888888"],
      "summary": "HR 联系方式规则命中"
    },
    {
      "id": "Q-08",
      "module": "规则",
      "question": "公司几点上班？",
      "expected_types": ["rule"],
      "must_contain": ["9:00", "18:00"],
      "summary": "标准工时 9:00–12:00，13:30–18:00"
    },
    {
      "id": "Q-09",
      "module": "规则",
      "question": "忘记打卡怎么办？",
      "expected_types": ["rule", "faq"],
      "must_contain": ["补卡"],
      "summary": "当日补卡，每月不超过 3 次"
    },
    {
      "id": "Q-10",
      "module": "规则",
      "question": "迟到怎么处理？",
      "expected_types": ["rule", "rag"],
      "must_contain": ["绩效", "旷工"],
      "summary": "30 分钟内扣绩效分，超 30 分钟按旷工处理"
    },
    {
      "id": "Q-11",
      "module": "RAG",
      "question": "婚假有几天？",
      "expected_types": ["rag", "faq"],
      "must_contain": ["3"],
      "summary": "婚假 3 天，领证后 6 个月内使用"
    },
    {
      "id": "Q-12",
      "module": "RAG",
      "question": "产假多少天？",
      "expected_types": ["rag"],
      "must_contain": ["98"],
      "summary": "产假 98 天，难产/多胞胎有追加"
    },
    {
      "id": "Q-13",
      "module": "RAG",
      "question": "每月几号发工资？",
      "expected_types": ["rag"],
      "must_contain": ["15"],
      "summary": "每月 15 日发放上月工资"
    },
    {
      "id": "Q-14",
      "module": "RAG",
      "question": "绩效等级分几档？",
      "expected_types": ["rag", "faq", "clarification", "miss"],
      "must_contain": ["绩效|等级|优秀|合格|A"],
      "summary": "A/B/C/D/E 五档"
    },
    {
      "id": "Q-15",
      "module": "RAG",
      "question": "新员工入职要带什么材料？",
      "expected_types": ["rag"],
      "must_contain": ["身份证", "学历"],
      "summary": "身份证、学历证书、离职证明等"
    },
    {
      "id": "Q-16",
      "module": "RAG",
      "question": "丧假可以请几天？",
      "expected_types": ["rag"],
      "must_contain": ["3"],
      "summary": "直系亲属丧假 3 天"
    },
    {
      "id": "Q-17",
      "module": "负向",
      "question": "公司食堂几点开饭？",
      "expected_types": ["miss", "clarification", "rule"],
      "must_contain": ["未|暂未|知识库|未提供"],
      "summary": "种子数据无此内容，应提示未找到依据"
    },
    {
      "id": "Q-18",
      "module": "负向",
      "question": "火星移民政策是什么？",
      "expected_types": ["miss", "clarification"],
      "must_contain": ["暂未", "知识库"],
      "summary": "无关问题，不应编造答案"
    },
    {
      "id": "Q-19",
      "module": "FAQ变体",
      "question": "报销要哪些步骤？",
      "expected_types": ["faq"],
      "must_contain": ["报销"],
      "summary": "换说法仍应命中报销 FAQ"
    },
    {
      "id": "Q-20",
      "module": "RAG",
      "question": "周末加班怎么算加班费？",
      "expected_types": ["rag", "faq"],
      "must_contain": ["2倍|2 倍|两倍|调休"],
      "summary": "周末加班 2 倍或调休（FAQ/RAG 均可）"
    }
  ],
  "multi_turn": [
    {
      "id": "T-01",
      "module": "工单-在职证明",
      "description": "完整提交在职证明工单",
      "steps": [
        {
          "question": "我要开一份在职证明",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["用途", "证明"]
        },
        {
          "question": "用来办签证，交给日本领事馆，要盖章，最好这周五前",
          "expected_types": ["ticket_confirm", "ticket_clarification"],
          "must_contain": ["日本", "签证"]
        },
        {
          "question": "确认提交",
          "action": "confirm_submit",
          "expected_types": ["ticket_submitted"],
          "must_contain": ["提交", "TK"]
        }
      ]
    },
    {
      "id": "T-02",
      "module": "工单-考勤异常",
      "description": "考勤异常说明提交",
      "steps": [
        {
          "question": "我要提交考勤异常说明",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["异常", "日期"]
        },
        {
          "question": "2026年7月3日, 打卡缺失, 忘记打卡",
          "expected_types": ["ticket_confirm", "ticket_clarification"],
          "must_contain": ["2026", "打卡"]
        },
        {
          "question": "确认提交",
          "action": "confirm_submit",
          "expected_types": ["ticket_submitted"],
          "must_contain": ["提交", "TK"]
        }
      ]
    },
    {
      "id": "T-03",
      "module": "工单-修改字段",
      "description": "确认前修改接收单位",
      "steps": [
        {
          "question": "我要开在职证明",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["用途|证明|接收"]
        },
        {
          "question": "用来办签证，交给日本领事馆，要盖章，最好这周五前",
          "expected_types": ["ticket_confirm", "ticket_clarification"],
          "must_contain": ["日本"]
        },
        {
          "question": "接收单位改成美国大使馆",
          "expected_types": ["ticket_confirm", "ticket_clarification", "ticket_qa"],
          "must_contain": ["美国"]
        }
      ]
    },
    {
      "id": "T-04",
      "module": "工单-类型选择",
      "description": "未指明类型时选择在职证明",
      "steps": [
        {
          "question": "提交一个新工单",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["证明", "工单"]
        },
        {
          "question": "1",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["用途", "证明"]
        }
      ]
    },
    {
      "id": "T-05",
      "module": "工单-问答切换",
      "description": "工单流程中询问 HR 电话后回到工单",
      "steps": [
        {
          "question": "我要开一份在职证明",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["用途|证明|接收"]
        },
        {
          "question": "HR电话是多少？",
          "expected_types": ["rule", "faq"],
          "must_contain": ["88888888"]
        },
        {
          "question": "继续修改",
          "action": "modify",
          "expected_types": ["ticket_clarification", "ticket_confirm", "ticket_qa"],
          "must_contain": ["修改", "证明"]
        }
      ]
    },
    {
      "id": "T-06",
      "module": "工单-提交后追问",
      "description": "提交后询问处理时长",
      "steps": [
        {
          "question": "我要开一份在职证明",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["用途|证明|接收"]
        },
        {
          "question": "用来办签证，交给日本领事馆，要盖章，最好这周五前",
          "expected_types": ["ticket_confirm", "ticket_clarification"],
          "must_contain": ["日本"]
        },
        {
          "question": "确认提交",
          "action": "confirm_submit",
          "expected_types": ["ticket_submitted"],
          "must_contain": ["提交"]
        },
        {
          "question": "这个大概要等几天？",
          "expected_types": ["ticket_qa", "ticket_clarification", "clarification"],
          "must_contain": ["工作日|天|处理"]
        }
      ]
    },
    {
      "id": "T-07",
      "module": "工单-信息变更",
      "description": "修改手机号工单（首轮识别）",
      "steps": [
        {
          "question": "我想修改手机号",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["变更|信息|手机"]
        }
      ]
    },
    {
      "id": "T-08",
      "module": "工单-校验",
      "description": "填完槽位后询问信息是否正确",
      "steps": [
        {
          "question": "我要开一份在职证明",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["用途|证明|接收"]
        },
        {
          "question": "用来办签证，交给日本领事馆，要盖章，最好这周五前",
          "expected_types": ["ticket_confirm", "ticket_clarification"],
          "must_contain": ["日本"]
        },
        {
          "question": "这样可以吗？",
          "expected_types": ["ticket_confirm", "ticket_clarification", "ticket_qa"],
          "must_contain": ["完整", "确认"]
        }
      ]
    },
    {
      "id": "T-09",
      "module": "工单-考勤修改",
      "description": "考勤异常确认前修改原因",
      "steps": [
        {
          "question": "我要提交考勤异常说明",
          "expected_types": ["ticket_clarification"],
          "must_contain": ["异常"]
        },
        {
          "question": "2026年7月3日, 打卡缺失, 忘记打卡",
          "expected_types": ["ticket_confirm", "ticket_clarification"],
          "must_contain": ["2026"]
        },
        {
          "question": "异常原因改成: 路上堵车",
          "expected_types": ["ticket_confirm", "ticket_clarification", "ticket_qa"],
          "must_contain": ["堵车"]
        }
      ]
    },
    {
      "id": "T-10",
      "module": "追问",
      "description": "规则回答后的考勤追问",
      "steps": [
        {
          "question": "忘记打卡怎么办？",
          "expected_types": ["rule", "faq"],
          "must_contain": ["补卡"]
        },
        {
          "question": "那迟到呢？",
          "expected_types": ["rule", "faq", "rag", "clarification"],
          "must_contain": ["迟到", "绩效", "旷工"]
        }
      ]
    }
  ]
}
